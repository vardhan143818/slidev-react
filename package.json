{
  "name": "slidev-react",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source React + MDX presentation app/runtime (not published to npm)",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist .generated output packages/*/dist",
    "changeset": "changeset",
    "build:packages": "pnpm -r --filter @slidev-react/core --filter @slidev-react/node --filter @slidev-react/cli run build:pkg",
    "dev:packages": "pnpm -r --parallel --filter @slidev-react/core --filter @slidev-react/node --filter @slidev-react/cli run dev:pkg",
    "dev": "vp dev",
    "dev:e2e": "vp dev --host 127.0.0.1 --port 4173",
    "build": "pnpm run build:packages && vp build",
    "make": "pnpm run build",
    "preview": "vp preview",
    "export:slides": "sh -c 'shift; pnpm exec slidev-react export \"$@\"' --",
    "export:slides:pdf": "sh -c 'shift; pnpm exec slidev-react export --format pdf \"$@\"' --",
    "export:slides:png": "sh -c 'shift; pnpm exec slidev-react export --format png \"$@\"' --",
    "lint:slides": "sh -c 'shift; pnpm exec slidev-react lint \"$@\"' --",
    "presentation:server": "node --import tsx ./scripts/presentation-server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vp test --run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "lint": "vp lint --type-aware --tsconfig tsconfig.json packages scripts e2e vite.config.ts vitest.config.ts playwright.config.ts postcss.config.mjs",
    "format": "vp fmt .",
    "format:check": "vp fmt --check .",
    "release:version": "changeset version && pnpm install --lockfile-only",
    "release:publish": "pnpm run build:packages && changeset publish",
    "prepare": "vp config"
  },
  "dependencies": {
    "@slidev-react/core": "workspace:*",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@antv/g-svg": "^2.1.1",
    "@antv/g2": "^5.4.8",
    "@changesets/cli": "2.29.6",
    "@mdx-js/react": "3.1.1",
    "@playwright/test": "^1.58.2",
    "@slidev-react/cli": "workspace:*",
    "@slidev-react/client": "workspace:*",
    "@slidev-react/node": "workspace:*",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.3.5",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.0",
    "lucide-react": "0.568.0",
    "mermaid": "11.12.3",
    "postcss": "^8.5.6",
    "tailwindcss": "4.2.1",
    "tsdown": "^0.21.2",
    "tsx": "^4.20.6",
    "typescript": "5.9.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "ws": "^8.18.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
