{
  "name": "slidev-react",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source React + MDX presentation app/runtime (not published to npm)",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist .generated output packages/*/dist",
    "changeset": "changeset",
    "build:packages": "pnpm -r --filter @slidev-react/core --filter @slidev-react/node --filter @slidev-react/cli run build:pkg",
    "dev:packages": "pnpm -r --parallel --filter @slidev-react/core --filter @slidev-react/node --filter @slidev-react/cli run dev:pkg",
    "dev": "vite",
    "dev:e2e": "vite --host 127.0.0.1 --port 4173",
    "build": "pnpm run build:packages && vite build",
    "make": "pnpm run build",
    "preview": "vite preview",
    "export:slides": "sh -c 'shift; pnpm exec slidev-react export \"$@\"' --",
    "export:slides:pdf": "sh -c 'shift; pnpm exec slidev-react export --format pdf \"$@\"' --",
    "export:slides:png": "sh -c 'shift; pnpm exec slidev-react export --format png \"$@\"' --",
    "lint:slides": "sh -c 'shift; pnpm exec slidev-react lint \"$@\"' --",
    "presentation:server": "node --import tsx ./scripts/presentation-server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest --run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "lint": "oxlint --type-aware --tsconfig tsconfig.json packages scripts e2e vite.config.ts vitest.config.ts playwright.config.ts postcss.config.mjs",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "release:version": "changeset version && pnpm install --lockfile-only",
    "release:publish": "pnpm run build:packages && changeset publish"
  },
  "dependencies": {
    "@mdx-js/mdx": "3.1.1",
    "@mdx-js/react": "3.1.1",
    "@slidev-react/core": "workspace:*",
    "katex": "0.16.33",
    "lucide-react": "0.568.0",
    "mermaid": "11.12.3",
    "plantuml-encoder": "1.4.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "rehype-katex": "7.0.1",
    "remark-gfm": "4.0.1",
    "remark-math": "6.0.0",
    "rough-notation": "^0.5.1",
    "shiki": "4.0.1",
    "shiki-magic-move": "1.2.1",
    "yaml": "2.8.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.6",
    "@playwright/test": "^1.58.2",
    "@slidev-react/cli": "workspace:*",
    "@slidev-react/client": "workspace:*",
    "@slidev-react/node": "workspace:*",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "oxfmt": "^0.36.0",
    "oxlint": "1.50.0",
    "oxlint-tsgolint": "^0.16.0",
    "postcss": "^8.5.6",
    "tailwindcss": "4.2.1",
    "tsdown": "0.21.0",
    "tsx": "^4.20.6",
    "typescript": "5.9.3",
    "vite": "^7.3.1",
    "vitest": "4.0.9",
    "ws": "^8.18.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
