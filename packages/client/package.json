{
  "name": "@slidev-react/client",
  "version": "0.4.9",
  "description": "Browser-side React app and presentation UI for slidev-react",
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/src/runtime/entry.d.ts",
      "import": "./dist/runtime.js",
      "default": "./dist/runtime.js"
    },
    "./runtime/manifest": {
      "types": "./dist/src/runtime/manifest.d.ts",
      "import": "./dist/runtime/manifest.js",
      "default": "./dist/runtime/manifest.js"
    },
    "./style.css": "./dist/style.css",
    "./manifest": "./dist/manifest.json",
    "./addons/mermaid": {
      "types": "./dist/src/addons/builtin/mermaid/index.d.ts",
      "import": "./dist/addons/mermaid.js",
      "default": "./dist/addons/mermaid.js"
    },
    "./addons/g2": {
      "types": "./dist/src/addons/builtin/g2/index.d.ts",
      "import": "./dist/addons/g2.js",
      "default": "./dist/addons/g2.js"
    },
    "./addons/g2/style.css": "./dist/addons/g2/style.css",
    "./addons/insight": {
      "types": "./dist/src/addons/builtin/insight/index.d.ts",
      "import": "./dist/addons/insight.js",
      "default": "./dist/addons/insight.js"
    },
    "./addons/insight/style.css": "./dist/addons/insight/style.css",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:pkg": "pnpm exec tsdown",
    "dev:pkg": "pnpm exec tsdown --watch",
    "prepack": "pnpm run build:pkg"
  },
  "dependencies": {
    "@antv/g-svg": "^2.1.1",
    "@antv/g2": "^5.4.8",
    "@slidev-react/core": "0.4.9",
    "katex": "0.16.33",
    "lucide-react": "0.568.0",
    "mermaid": "11.12.3",
    "plantuml-encoder": "1.4.0",
    "shiki": "4.0.1",
    "shiki-magic-move": "1.2.1",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "@mdx-js/react": ">=3.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
