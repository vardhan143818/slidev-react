{
  "name": "@slidev-react/client",
  "version": "0.4.0",
  "description": "Browser-side React app and presentation UI for slidev-react",
  "license": "MIT",
  "scripts": {
    "build:pkg": "pnpm exec tsdown",
    "dev:pkg": "pnpm exec tsdown --watch",
    "prepack": "pnpm run build:pkg"
  },
  "type": "module",
  "types": "./dist/src/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css",
    "./manifest": "./dist/manifest.json",
    "./addons/mermaid": {
      "types": "./dist/src/addons/mermaid/index.d.ts",
      "import": "./dist/addons/mermaid.js"
    },
    "./addons/g2": {
      "types": "./dist/src/addons/g2/index.d.ts",
      "import": "./dist/addons/g2.js"
    },
    "./addons/g2/style.css": "./dist/addons/g2/style.css",
    "./addons/insight": {
      "types": "./dist/src/addons/insight/index.d.ts",
      "import": "./dist/addons/insight.js"
    },
    "./addons/insight/style.css": "./dist/addons/insight/style.css",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@slidev-react/core": "workspace:*",
    "katex": "0.16.33",
    "lucide-react": "0.568.0",
    "plantuml-encoder": "1.4.0",
    "shiki": "4.0.1",
    "shiki-magic-move": "1.2.1",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "@antv/g-svg": ">=2.0.0",
    "@antv/g2": ">=5.0.0",
    "@mdx-js/react": ">=3.0.0",
    "mermaid": ">=11.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "@antv/g-svg": {
      "optional": true
    },
    "@antv/g2": {
      "optional": true
    },
    "mermaid": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
